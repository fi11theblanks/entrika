<nav class="sidebar" id="appSidebar">
  <%# ── Header / logo toggle ── %>
  <div class="sidebar-header">
    <button class="sidebar-toggle" id="sidebarToggleBtn" aria-label="Toggle sidebar">
      <%= image_tag "logo.svg", class: "sidebar-logo", alt: "Entrika" %>
    </button>
    <span class="sidebar-wordmark">Entrika</span>
  </div>
  <div class="sidebar-nav">
    <ul class="list-unstyled mb-0">
      <%# ── Home ── %>
      <li class="mb-1" data-turbo-permanent>
        <%= link_to root_path,
              class: "sidebar-link #{current_page?(root_path) ? 'is-active' : ''}",
              data: { label: "Home" } do %>
          <i class="fa-solid fa-house nav-icon"></i>
          <span class="sidebar-link__label">Home</span>
        <% end %>
      </li>
      <%# ── Dashboard ── %>
      <% if user_signed_in? %>
        <li class="mb-1">
          <button class="sidebar-link"
                data-bs-toggle="collapse"
                data-bs-target="#dashboard-collapse"
                aria-expanded="false"
                data-label="Dashboard">
            <i class="fa-solid fa-book-open nav-icon"></i>
            <span class="sidebar-link__label">Dashboard</span>
            <i class="fa-solid fa-chevron-right chevron"></i>
          </button>
          <div class="collapse" id="dashboard-collapse" data-turbo-permanent>
            <ul class="btn-toggle-nav list-unstyled">
              <li><%= link_to "Overview", dashboard_path %></li>
              <li><%= link_to "Sites Analyzed", sitesanalyzed_path %></li>
            </ul>
          </div>
        </li>
      <% end %>
      <%# ── Directory ── %>
      <li class="mb-1" data-turbo-permanent>
        <%= link_to companies_path,
              class: "sidebar-link #{request.path.start_with?('/companies') ? 'is-active' : ''}",
              data: { label: "Directory" } do %>
          <i class="fa-solid fa-link nav-icon"></i>
          <span class="sidebar-link__label">Directory</span>
        <% end %>
      </li>
      <%# ── Search ── %>
      <li class="mb-1" data-turbo-permanent>
        <div class="sidebar-link" data-label="Search">
          <i class="fa-solid fa-magnifying-glass nav-icon search-icon-collapsed" id="searchIconCollapsed"></i>
          <%= form_with url: companies_path, method: :get, class: "search-form" do %>
            <div class="search-input-wrapper">
              <%= label_tag :query, "Search companies", class: "visually-hidden" %>
              <%= text_field_tag :query, params[:query],
                    class: "search-input",
                    placeholder: "Search companies" %>
              <%# <button type="submit" class="search-submit">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button> %>
            </div>
          <% end %>
        </div>
      </li>
      <%# ── News Feed ── %>
      <li class="mb-1" data-turbo-permanent>
        <button class="sidebar-link" data-label="News Feed">
          <i class="fa-solid fa-rss nav-icon"></i>
          <span class="sidebar-link__label">News Feed</span>
        </button>
      </li>
      <li class="sidebar-divider"></li>
      <%# ── Settings ── %>
      <% if user_signed_in? %>
        <li class="mb-1">
          <button class="sidebar-link"
                data-bs-toggle="collapse"
                data-bs-target="#settings-collapse"
                aria-expanded="false"
                data-label="Settings">
            <%= image_tag "avatar.png", alt: "sample avatar", class: "nav-icon" %>
            <span class="sidebar-link__label">Profile</span>
            <i class="fa-solid fa-chevron-right chevron"></i>
          </button>
          <div class="collapse" id="settings-collapse" data-turbo-permanent>
            <ul class="btn-toggle-nav list-unstyled">
              <li>
                <%= link_to "Settings", dashboard_path %>
              </li>
              <li>
                <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete } %>
              </li>
            </ul>
          </div>
        </li>
      <% else %>
        <li class="mb-1">
          <%= link_to new_user_session_path,
        class: "sidebar-link",
        data: { label: "Sign In" } do %>
            <i class="fa-solid fa-gear nav-icon"></i>
            <span class="sidebar-link__label">Sign In</span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
  <%# </div> %>
</nav>
<%# ── Toggle JS ── %>
<script>
  var sidebar = document.getElementById('appSidebar');
  var toggleBtn = document.getElementById('sidebarToggleBtn');

  if (localStorage.getItem('sidebarCollapsed') === 'true') {
    sidebar.classList.add('collapsed');
  }

  toggleBtn.addEventListener('click', () => {
    sidebar.classList.toggle('collapsed');
    localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
  });

  document.getElementById('searchIconCollapsed').addEventListener('click', () => {
    sidebar.classList.remove('collapsed');
    localStorage.setItem('sidebarCollapsed', 'false');
  });
</script>
