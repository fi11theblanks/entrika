<nav class="sidebar ml-3" id="appSidebar">
  <%# ── Hamburger toggle ── %>
  <button class="sidebar-toggle" id="sidebarToggleBtn" aria-label="Toggle sidebar">
    <span class="toggle-icon" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
    <span class="toggle-label">Menu</span>
  </button>
  <div class="sidebar-nav">
    <ul class="list-unstyled mb-0">
      <%# ── Home ── %>
      <li class="mb-1">
        <button class="btn-toggle"
                data-bs-toggle="collapse"
                data-bs-target="#home-collapse"
                aria-expanded="true"
                data-label="Home">
          <%= link_to root_path do %>
            <i class="fa-solid fa-house nav-icon"></i>
          <% end %>
          <span class="nav-label">Home</span>
          <i class="fa-solid fa-chevron-right chevron"></i>
        </button>
        <div class="collapse show" id="home-collapse">
          <ul class="btn-toggle-nav list-unstyled">
            <li><a href="#">Overview</a></li>
            <li><a href="#">Updates</a></li>
            <li><a href="#">Reports</a></li>
          </ul>
        </div>
      </li>
      <%# ── Dashboard ── %>
      <li class="mb-1">
        <button class="btn-toggle"
                data-bs-toggle="collapse"
                data-bs-target="#dashboard-collapse"
                aria-expanded="false"
                data-label="Dashboard">
          <%= link_to "dashboard" do %>
            <i class="fa-solid fa-gauge nav-icon"></i>
          <% end %>
          <span class="nav-label">Dashboard</span>
          <i class="fa-solid fa-chevron-right chevron"></i>
        </button>
        <div class="collapse" id="dashboard-collapse">
          <ul class="btn-toggle-nav list-unstyled">
            <li><a href="#">Risk Overview</a></li>
            <li><a href="#">Sites Analyzed</a></li>
            <li><a href="#">Recents</a></li>
          </ul>
        </div>
      </li>
      <%# ── Companies ── %>
      <li class="mb-1">
        <button class="btn-toggle"
                aria-expanded="false"
                data-label="Account">
          <%= link_to companies_path do %>
            <i class="fa-solid fa-city nav-icon"></i>
          <% end %>
          <span class="nav-label">Companies</span>
          <i class="fa-solid hidden"></i>
        </button>
      </li>
      <%# ── Search ── %>
      <li class="mb-1 sidebar-search">
        <div class="btn-toggle" data-label="Search">
          <i class="fa-solid fa-magnifying-glass nav-icon search-icon-collapsed" id="searchIconCollapsed"></i>
          <%= form_with url: companies_path, method: :get, class: "search-form" do %>
            <div class="search-input-wrapper">
              <%= label_tag :query, "Search companies", class: "visually-hidden" %>
              <%= text_field_tag :query,
              params[:query],
              class: "form-control",
              placeholder: "Type here"
            %>
              <button type="submit" class="search-submit">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button>
            </div>
          <% end %>
        </div>
      </li>
      <%# ── NewsFeed── %>
      <li class="mb-1">
        <button class="btn-toggle"
                aria-expanded="false"
                data-label="Account">
          <i class="fa-solid fa-rss nav-icon"></i>
          <span class="nav-label">News Feed</span>
          <i class="fa-solid hidden"></i>
        </button>
      </li>
      <li class="sidebar-divider"></li>
      <%# ── Settings ── %>
      <li class="mb-1">
        <button class="btn-toggle"
                data-bs-toggle="collapse"
                data-bs-target="#account-collapse"
                aria-expanded="false"
                data-label="Account">
          <i class="fa-solid fa-gear nav-icon"></i>
          <span class="nav-label">Settings</span>
          <i class="fa-solid fa-chevron-right chevron"></i>
        </button>
        <div class="collapse" id="account-collapse">
          <ul class="btn-toggle-nav list-unstyled">
            <li><a href="#">Profile</a></li>
            <li><a href="#">Settings</a></li>
            <li>
              <% if user_signed_in? %>
                <%= link_to "Sign Out", destroy_user_session_path, data: {turbo_method: :delete} %>
              <% else %>
                <%= link_to "Sign In", new_user_session_path %>
              <% end %>
            </li>
          </ul>
        </div>
      </li>
    </ul>
  </div>
</nav>
<%# ── Toggle JS ── %>
<script>
  var sidebar = document.getElementById('appSidebar');
  var toggleBtn = document.getElementById('sidebarToggleBtn');

  if (localStorage.getItem('sidebarCollapsed') === 'true') {
    sidebar.classList.add('collapsed');
  }

  toggleBtn.addEventListener('click', () => {
    sidebar.classList.toggle('collapsed');
    localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
  });

  document.getElementById('searchIconCollapsed').addEventListener('click', () => {
    sidebar.classList.remove('collapsed');
    localStorage.setItem('sidebarCollapsed', 'false');
  });
</script>
