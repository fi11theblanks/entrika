<div class="dashboard-index">
  <header class="dashboard-header">
    <div class="dashboard-header__top">
      <h1 class="dashboard-title">Sites Analyzed</h1>
    </div>
  </header>
  <ul class="nav tabs-underlined" id="myTab" role="tablist">
    <li class="nav-item" role="presentation">
      <span class="nav-link tab-underlined active dashboard-link" id="sites-tab" data-bs-toggle="tab" data-bs-target="#sites-tab-pane" role="tab" aria-controls="sites-tab-pane" aria-selected="true">All Sites</span>
    </li>
    <% @statuses.each do |status| %>
      <li class="nav-item" role="presentation">
        <span class="nav-link tab-underlined dashboard-link" id="<%= status %>-tab" data-bs-toggle="tab" data-bs-target="#<%= status %>-tab-pane" role="tab" aria-controls="<%= status %>-tab-pane" aria-selected="false"><%= status.capitalize %> Sites</span>
      </li>
    <% end %>
  </ul>
  <div class="tab-content" id="myTabContent">
    <div class="tab-pane fade py-3 show active" id="sites-tab-pane" role="tabpanel" aria-labelledby="sites-tab" tabindex="0">
      <% @registrations.each do |registration| %>
        <%= render "companies/company_card", company: registration.company, registration: registration %>
      <% end %>
    </div>
    <% @statuses.each do |status| %>
      <div class="tab-pane fade py-3" id="<%= status %>-tab-pane" role="tabpanel" aria-labelledby="<%= status %>-tab" tabindex="0">
        <% @registrations.where(status: status).each do |registration| %>
          <%= render "companies/company_card", company: registration.company, registration: registration %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
