<%= turbo_stream_from @company %>
<div class="row g-4">
  <div class="col-7">
    <%= render "company_card", company: @company, registration: @registration %>
    <h4 class="section-heading section-heading--tos">What you're agreeing to</h4>
    <p class="section-intro section-intro--tos"><%= @company.tos_summary %></p>
    <h4 class="section-heading section-heading--privacy">Privacy in plain English</h4>
    <p class="section-intro section-intro--privacy"><%= @company.privacy_summary %></p>
    <h4 class="section-heading section-heading--tos">Terms of Service Breakdown</h4>
    <% tos_parts = @company.tos_analysis.to_s.split(/(?=(?:Clause \d|Red flag \d|Third-party sharing:|A real-world scenario:|Privacy advocate verdict:))/).map(&:strip).reject(&:blank?) %>
    <% tos_bullets = tos_parts.select { |p| p.match?(/\A(?:Clause \d|Red flag \d)/) } %>
    <% if tos_bullets.any? %>
      <p class="analysis-opening"><%= tos_parts.reject { |p| p.match?(/\A(?:Clause \d|Red flag \d|Third-party|A real-world|Privacy advocate)/) }.first %></p>
      <span class="analysis-section-label analysis-section-label--clauses">Key Clauses</span>
      <ul class="analysis-bullets analysis-bullets--clauses">
        <% tos_bullets.each do |b| %>
          <li><i class="fa-solid fa-key"></i></span><span><%= b.sub(/\A(?:Clause|Red flag) \d+\s*\(([^)]+)\):\s*/i, '\1: ') %></span></li>
      <% end %>
    </ul>
    <% tos_sharing = tos_parts.select { |p| p.start_with?("Third-party sharing:") } %>
    <% if tos_sharing.any? %>
      <span class="analysis-section-label analysis-section-label--sharing">Data Sharing</span>
      <ul class="analysis-bullets analysis-bullets--sharing">
        <% tos_sharing.each do |m| %>
          <li><i class="fa-solid fa-database"></i><span><%= m.sub(/\AThird-party sharing:\s*/i, "").sub(/\A./) { |c| c.upcase } %></span></li>
        <% end %>
      </ul>
    <% end %>
    <% if (tos_scenario = tos_parts.find { |p| p.start_with?("A real-world scenario:") }) %>
      <div class="analysis-scenario">
        <span class="analysis-scenario__label">Real-world scenario:</span>
        <span><%= tos_scenario.sub(/\AA real-world scenario:\s*/i, "").sub(/\A./) { |c| c.upcase } %></span>
      </div>
    <% end %>
    <% if (tos_verdict = tos_parts.find { |p| p.start_with?("Privacy advocate verdict:") }) %>
      <div class="analysis-verdict">
        <span class="analysis-verdict__label">Verdict:</span>
        <span><%= tos_verdict.sub(/\APrivacy advocate verdict:\s*/i, "").sub(/\A./) { |c| c.upcase } %></span>
      </div>
    <% end %>
  <% elsif @company.tos_analysis.present? %>
    <% raw_sections = @company.tos_analysis.split(/(?=(?:Concerning clauses:|Data sharing:|Known incidents:|Verdict:))/).map(&:strip).reject(&:blank?) %>
    <% raw_sections.each do |section| %>
      <% if section.start_with?("Verdict:") %>
        <div class="analysis-verdict">
          <span class="analysis-verdict__label">Verdict:</span>
          <span><%= section.sub(/\AVerdict:\s*/i, "") %></span>
        </div>
      <% elsif section.start_with?("Known incidents:") %>
        <span class="analysis-section-label analysis-section-label--incidents">Known Incidents</span>
        <ul class="analysis-bullets analysis-bullets--incidents">
          <% items = section
       .sub(/\AKnown incidents:\s*/i, "")
       .split(/\n-\s*|(?<!\A)\s+-\s+/)
       .map { |item| item.strip.sub(/\A-\s*/, "") }
       .reject(&:blank?) %>
          <% items.each do |item| %>
            <%# <% section.sub(/\AKnown incidents:\s*/i, "").split(/\n-\s*|(?<!\A)\s+-\s+/).map(&:strip).reject(&:blank?).each do |item| %>
              <li><i class="fa-solid fa-burst"></i><span><%= item %></span></li>
            <% end %>
          </ul>
        <% elsif section.start_with?("Data sharing:") %>
          <span class="analysis-section-label analysis-section-label--sharing">Data Sharing</span>
          <ul class="analysis-bullets analysis-bullets--sharing">
            <% items = section
       .sub(/\AData Sharing:\s*/i, "")
       .split(/\n-\s*|(?<!\A)\s+-\s+/)
       .map { |item| item.strip.sub(/\A-\s*/, "") }
       .reject(&:blank?) %>
            <% items.each do |item| %>
              <li><i class="fa-solid fa-database"></i><span><%= item %></span></li>
            <% end %>
          </ul>
        <% elsif section.start_with?("Concerning clauses:") %>
          <span class="analysis-section-label analysis-section-label--clauses">Concerning Clauses</span>
          <ul class="analysis-bullets analysis-bullets--clauses">
            <% items = section
       .sub(/\AConcerning clauses:\s*/i, "")
       .split(/\n-\s*|(?<!\A)\s+-\s+/)
       .map { |item| item.strip.sub(/\A-\s*/, "") }
       .reject(&:blank?) %>
            <% items.each do |item| %>
              <li><i class="fa-solid fa-circle-exclamation"></i><span><%= item %></span></li>
            <% end %>
          </ul>
        <% else %>
          <p class="analysis-opening"><%= section %></p>
        <% end %>
      <% end %>
    <% end %>
    <h4 class="section-heading section-heading--privacy">Privacy Policy Breakdown</h4>
    <% priv_parts = @company.privacy_analysis.to_s.split(/(?=(?:Clause \d|Red flag \d|Third-party sharing:|A real-world scenario:|Privacy advocate verdict:))/).map(&:strip).reject(&:blank?) %>
    <% priv_bullets = priv_parts.select { |p| p.match?(/\A(?:Clause \d|Red flag \d)/) } %>
    <% if priv_bullets.any? %>
      <p class="analysis-opening"><%= priv_parts.reject { |p| p.match?(/\A(?:Clause \d|Red flag \d|Third-party|A real-world|Privacy advocate)/) }.first %></p>
      <span class="analysis-section-label analysis-section-label--clauses">Red Flags</span>
      <ul class="analysis-bullets analysis-bullets--clauses">
        <% priv_bullets.each do |b| %>
          <li><i class="fa-solid fa-flag"></i><span><%= b.sub(/\A(?:Clause|Red flag) \d+\s*\(([^)]+)\):\s*/i, '\1: ') %></span></li>
        <% end %>
      </ul>
      <% priv_sharing = priv_parts.select { |p| p.start_with?("Third-party sharing:") } %>
      <% if priv_sharing.any? %>
        <span class="analysis-section-label analysis-section-label--sharing">Who Gets Your Data</span>
        <ul class="analysis-bullets analysis-bullets--sharing">
          <% priv_sharing.each do |m| %>
            <li><i class="fa-solid fa-hand"></i><span><%= m.sub(/\AThird-party sharing:\s*/i, "").sub(/\A./) { |c| c.upcase } %></span></li>
          <% end %>
        </ul>
      <% end %>
      <% if (priv_scenario = priv_parts.find { |p| p.start_with?("A real-world scenario:") }) %>
        <div class="analysis-scenario">
          <span class="analysis-scenario__label">Real-world scenario:</span>
          <span><%= priv_scenario.sub(/\AA real-world scenario:\s*/i, "") %></span>
        </div>
      <% end %>
      <% if (priv_verdict = priv_parts.find { |p| p.start_with?("Privacy advocate verdict:") }) %>
        <div class="analysis-verdict">
          <span class="analysis-verdict__label">Verdict:</span>
          <span><%= priv_verdict.sub(/\APrivacy advocate verdict:\s*/i, "").sub(/\A./) { |c| c.upcase } %></span>
        </div>
      <% end %>
    <% elsif @company.privacy_analysis.present? %>
      <% priv_raw_sections = @company.privacy_analysis.split(/(?=(?:Concerning clauses:|Data sharing:|Known incidents:|Verdict:))/).map(&:strip).reject(&:blank?) %>
      <% priv_raw_sections.each do |section| %>
        <% if section.start_with?("Verdict:") %>
          <div class="analysis-verdict">
            <span class="analysis-verdict__label">Verdict:</span>
            <span><%= section.sub(/\AVerdict:\s*/i, "") %></span>
          </div>
        <% elsif section.start_with?("Known incidents:") %>
          <%# skipped — same incidents already shown in TOS breakdown %>
        <% elsif section.start_with?("Data sharing:") %>
          <span class="analysis-section-label analysis-section-label--sharing">Who Gets Your Data</span>
          <ul class="analysis-bullets analysis-bullets--sharing">
            <% items = section
              .sub(/\AData sharing:\s*/i, "")
              .split(/\n-\s*|(?<!\A)\s+-\s+/)
              .map { |item| item.strip.sub(/\A-\s*/, "") }
              .reject(&:blank?) %>
            <% items.each do |item| %>
              <%# <% section.sub(/\AData sharing:\s*/i, "").split(/ - /).map(&:strip).reject(&:blank?).each do |item| %>
                <li><i class="fa-solid fa-hand"></i><span><%= item %></span></li>
              <% end %>
            </ul>
          <% elsif section.start_with?("Concerning clauses:") %>
            <span class="analysis-section-label analysis-section-label--clauses">Privacy Issues</span>
            <ul class="analysis-bullets analysis-bullets--clauses">
              <% items = section
                .sub(/\AConcerning clauses:\s*/i, "")
                .split(/\n-\s*|(?<!\A)\s+-\s+/)
                .map { |item| item.strip.sub(/\A-\s*/, "") }
                .reject(&:blank?) %>
              <% items.each do |item| %>
                <%# <% section.sub(/\AConcerning clauses:\s*/i, "").split(/\n-\s*|(?<!\A)\s+-\s+/).map(&:strip).reject(&:blank?).each do |item| %>
                  <li><i class="fa-solid fa-unlock"></i><span><%= item %></span></li>
                <% end %>
              </ul>
            <% else %>
              <p class="analysis-opening"><%= section %></p>
            <% end %>
          <% end %>
        <% end %>
        <div class="company-links">
          <% if @company.tos_url.present? %>
            <%= link_to "Read the full Terms of Service →", @company.tos_url, target: "_blank", class: "company-link" %>
          <% end %>
          <% if @company.privacy_url.present? %>
            <%= link_to "Read the full Privacy Policy →", @company.privacy_url, target: "_blank", class: "company-link" %>
          <% end %>
        </div>
        <h4 class="section-heading">Safer Alternatives</h4>
        <% if @alternatives.any? %>
          <p class="section-intro">Similar services with a lower risk score.</p>
          <div class="alternatives-grid">
            <% @alternatives.each do |alt| %>
              <%= link_to company_path(alt), class: "alternative-card", data: { turbo_prefetch: false } do %>
                <div class="alternative-card__name"><%= alt.name %></div>
                <%= render "companies/risk_badge", icon: "⚠", score: alt.risk_label %>
                <div class="alternative-card__url"><%= alt.url %></div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="section-intro">We have no alternative sites that are lower risk than <%= @company.name %>! <br> Analyze another to compare.</p>
        <% end %>
      </div>
      <div class="col-5">
        <div class="chat-card" style="height: 90vh; position: sticky; top: 2rem;">
          <%# Header %>
          <div class="chat-header">
            <div class="chat-header__avatar">
              <%= image_tag "logo.svg", alt: "Entrika", class: "chat-header__avatar-img" %>
            </div>
            <div>
              <div class="chat-header__name">Entrika</div>
              <div class="chat-header__sub">Ask about this company's policies</div>
            </div>
          </div>
          <%# Messages %>
          <div class="chat-messages" id="messages">
            <% if @registration&.messages&.any? %>
              <% @registration.messages.each do |message| %>
                <%= render "messages/message", message: message %>
              <% end %>
            <% else %>
              <div class="chat-bubble-row chat-bubble-row--assistant">
                <div class="chat-avatar">
                  <svg class="chat-avatar__logo" viewBox="0 0 1200 1200" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="600" cy="600" r="600" fill="#E63D00" fill-opacity="0.76"/>
                    <path d="M600 113C826.591 113 1013 330.748 1013 603C1013 635.385 1003.4 657.281 987.658 672.155C971.64 687.295 948.026 696.343 917.858 700.293C857.26 708.226 775.104 695.031 690.093 676.837C605.988 658.837 518.982 635.901 451.572 625.825C417.85 620.785 387.801 618.74 364.682 622.495C341.529 626.256 322.389 636.487 316.36 658.341C296.87 728.992 336.537 801.433 394.617 853.793C452.862 906.302 532.921 941.797 600.71 936.975C659.682 932.779 701.946 924.036 735.157 902.012C768.534 879.878 791.343 845.301 813.808 792.922C820.51 777.294 835.461 767 851.939 767H931.638C958.256 767 976.163 791.829 967.234 815.01C902.707 982.532 765.409 1093 600 1093C373.409 1093 187 875.252 187 603C187 330.748 373.409 113 600 113Z" fill="#010101" stroke="black" stroke-width="20"/>
                    <path d="M669.151 213.884C749.419 231.064 815.903 293.594 862.899 353.429C886.262 383.174 904.492 411.847 916.879 433.089C923.067 443.701 927.786 452.438 930.945 458.497C931.11 458.814 931.27 459.125 931.427 459.428C926.526 462.115 919.406 465.885 910.386 470.292C891.94 479.304 865.603 490.96 834.108 501.508C770.919 522.671 687.93 539.041 606.514 521.616C525.248 504.222 459.994 456.229 414.799 412.088C392.248 390.062 374.833 369.133 363.075 353.734C357.357 346.247 352.988 340.079 350.023 335.746C350.463 335.338 350.928 334.909 351.417 334.46C356.173 330.095 363.182 323.869 372.126 316.495C390.028 301.736 415.606 282.439 446.309 264.266C508.071 227.709 588.883 196.704 669.151 213.884Z" fill="#D9D9D9" stroke="black" stroke-width="20"/>
                    <circle class="chat-avatar__pupil" cx="657.5" cy="368.5" r="144" fill="black" stroke="black" stroke-width="20"/>
                  </svg>
                </div>
                <div class="chat-bubble chat-bubble--assistant">
                  Ask me anything about <%= @company.name %>'s terms or privacy policy.
                </div>
              </div>
            <% end %>
          </div>
          <%# Input %>
          <div id="new-empty-form">
            <%= render "messages/form", company: @company, message: @message %>
          </div>
        </div>
      </div>
    </div>
  </div>
