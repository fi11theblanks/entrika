<div class="row g-4">
  <div class="col-7">
    <%= render "company_card", company: @company %>

    <h4 class="section-heading">Terms of Service Summary</h4>
    <p><%= @company.tos_summary %></p>

    <h4 class="section-heading">Privacy Policy Summary</h4>
    <p><%= @company.privacy_summary %></p>

    <h4 class="section-heading">Analysis</h4>
    <p><%= @company.tos_analysis %></p>
    <p><%= @company.privacy_analysis %></p>
    <ul class="company-meta-list">
      <li><strong>Risk Score:</strong> <%= @company.risk_label %></li>
      <li>
        <strong>Privacy Policy:</strong>
        <%= @company.privacy_url.present? ? link_to(@company.privacy_url, @company.privacy_url, target: "_blank") : "Not available" %>
      </li>
      <li>
        <strong>Terms of Service:</strong>
        <%= @company.tos_url.present? ? link_to(@company.tos_url, @company.tos_url, target: "_blank") : "Not available" %>
      </li>
    </ul>

    <h4 class="section-heading">Flagged Clauses</h4>
    <div class="flagged-clause">They do something with your data</div>
    <div class="flagged-clause">They do something with your data</div>
    <div class="flagged-clause">They do something with your data</div>
  </div>

  <div class="col-5">
    <div class="chat-card" style="height: 90vh; position: sticky; top: 2rem;">

      <%# Header %>
      <div class="chat-header">
        <div class="chat-header__avatar logo-sprite"></div>
        <div>
          <div class="chat-header__name">Entrika</div>
          <div class="chat-header__sub">Ask about this company's policies</div>
        </div>
      </div>

      <%# Messages %>
      <div class="chat-messages" id="messages">
        <% if @registration&.messages&.any? %>
          <% @registration.messages.each do |message| %>
            <%= render "messages/message", message: message %>
          <% end %>
        <% else %>
          <div class="chat-bubble-row chat-bubble-row--assistant">
            <div class="chat-avatar logo-sprite--sm"></div>
            <div class="chat-bubble chat-bubble--assistant">
              Ask me anything about <%= @company.name %>'s terms or privacy policy.
            </div>
          </div>
        <% end %>
      </div>

      <%# Input %>
      <div id="new-empty-form">
        <%= render "messages/form", company: @company, message: @message %>
      </div>

    </div>
  </div>
</div>
