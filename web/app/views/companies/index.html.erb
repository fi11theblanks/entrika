<div class="companies-index">
  <header class="companies-header">
    <div class="companies-header__top">
      <% if params[:query].present? %>
        <h1 class="companies-title">Results for "<%= params[:query] %>"</h1>
      <% else %>
        <h1 class="companies-title">Company Directory</h1>
      <% end %>
      <span class="companies-count"><%= @companies.count %> analysed</span>
    </div>
  </header>
  <% if @companies.any? %>
    <div class="company-list">
      <% @companies.order(name: :asc).each do |company| %>
        <%= render "company_home_index_card", company: company %>
      <% end %>
    </div>
  <% else %>
  <p class="companies-empty">No companies found.</p>
<% end %>
</div>
