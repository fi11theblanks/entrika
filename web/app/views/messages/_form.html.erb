<% if user_signed_in? %>
  <%= simple_form_for [company, message], html: { class: "chat-form", data: { controller: "submit-on-enter" } } do |f| %>
    <%= f.input :content,
          label: false,
          input_html: {
            class: "chat-input",
            placeholder: "Ask a question...",
            rows: 1,
            data: { action: "keydown->submit-on-enter#submit" }
          } %>
    <%= f.submit "Send", class: "chat-send-btn" %>
  <% end %>
<% else %>
  <div class="chat-form chat-form--locked">
    <span class="chat-input chat-input--placeholder">Sign in to ask questions</span>
    <%= link_to "Sign in", new_user_session_path, class: "chat-send-btn" %>
  </div>
<% end %>
