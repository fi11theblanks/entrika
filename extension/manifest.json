{
  "manifest_version": 3,
  "name": "Entrika",
  "version": "1.0.0",
  "description": "Entrika browser extension",
  "permissions": ["activeTab"],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  },
  "background": {
    "service_worker": "javascript/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["javascript/content.js"]
    }
  ]
}
